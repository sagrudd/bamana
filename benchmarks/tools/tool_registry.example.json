{
  "registry_version": "1.0.0",
  "tools": [
    {
      "id": "bamana",
      "display_name": "Bamana",
      "category": "mixed",
      "wrapper": {
        "type": "shell_script",
        "path": "benchmarks/tools/wrappers/bamana.sh",
        "entrypoint": "benchmarks/tools/wrappers/bamana.sh",
        "orchestration_module": "benchmarks/modules/run_bamana.nf",
        "cli_contract": "benchmarks/tools/wrappers/wrapper_cli_contract.md",
        "timing_strategy": "plan_then_run_benchmark",
        "supports_threads": true,
        "supports_subsample": true,
        "supports_sort": true,
        "supports_index": true,
        "supports_consume": true
      },
      "version_command": "\"${bamana_bin}\" --version",
      "supports_scenarios": [
        "mapped_bam_pipeline",
        "unmapped_bam_pipeline",
        "fastq_consume_pipeline",
        "subsample_only"
      ],
      "workflow_variants": [
        {
          "scenario": "mapped_bam_pipeline",
          "workflow_variant_id": "bamana_subsample_sort_partial_index",
          "status": "supported",
          "operation_ordering": ["subsample", "sort"],
          "notes": "Partial because executable BAM index creation remains deferred."
        },
        {
          "scenario": "mapped_bam_pipeline",
          "workflow_variant_id": "bamana_subsample_sort_index",
          "status": "planned",
          "operation_ordering": ["subsample", "sort", "index"],
          "notes": "Shell wrapper skeleton exists and will fail honestly at runtime if the required Bamana index path is not yet implemented."
        },
        {
          "scenario": "unmapped_bam_pipeline",
          "workflow_variant_id": "bamana_subsample_only",
          "status": "supported",
          "operation_ordering": ["subsample"],
          "notes": "Direct BAM subsampling path."
        },
        {
          "scenario": "fastq_consume_pipeline",
          "workflow_variant_id": "bamana_consume_unmapped_bam",
          "status": "supported",
          "operation_ordering": ["consume"],
          "notes": "Consumes FASTQ.GZ into unmapped BAM."
        },
        {
          "scenario": "fastq_consume_pipeline",
          "workflow_variant_id": "bamana_consume_only",
          "status": "planned",
          "operation_ordering": ["consume"],
          "notes": "Alias wrapper variant for explicit consume-only benchmarking."
        },
        {
          "scenario": "fastq_consume_pipeline",
          "workflow_variant_id": "bamana_consume_sort",
          "status": "planned",
          "operation_ordering": ["consume", "sort"],
          "notes": "Wrapper skeleton exists for future normalization-plus-sort benchmarking."
        },
        {
          "scenario": "fastq_consume_pipeline",
          "workflow_variant_id": "bamana_consume_sort_index",
          "status": "planned",
          "operation_ordering": ["consume", "sort", "index"],
          "notes": "Wrapper skeleton exists and will fail honestly if the required runtime subcommands are unavailable."
        },
        {
          "scenario": "subsample_only",
          "workflow_variant_id": "bamana_subsample_only",
          "status": "supported",
          "operation_ordering": ["subsample"],
          "notes": "Supports BAM and FASTQ.GZ."
        }
      ],
      "notes": "Primary project tool; benchmark-native workflow remains explicit in results."
    },
    {
      "id": "samtools",
      "display_name": "samtools",
      "category": "bam_toolkit",
      "wrapper": {
        "type": "shell_script",
        "path": "benchmarks/tools/wrappers/samtools.sh",
        "entrypoint": "benchmarks/tools/wrappers/samtools.sh",
        "orchestration_module": "benchmarks/modules/run_samtools.nf",
        "cli_contract": "benchmarks/tools/wrappers/wrapper_cli_contract.md",
        "timing_strategy": "plan_then_run_benchmark",
        "supports_threads": true,
        "supports_subsample": true,
        "supports_sort": true,
        "supports_index": true,
        "supports_consume": false
      },
      "version_command": "samtools --version",
      "supports_scenarios": [
        "mapped_bam_pipeline",
        "unmapped_bam_pipeline",
        "subsample_only"
      ],
      "workflow_variants": [
        {
          "scenario": "mapped_bam_pipeline",
          "workflow_variant_id": "samtools_view_sort_index",
          "status": "supported",
          "operation_ordering": ["view_subsample", "sort", "index"],
          "notes": "Canonical BAM comparator path."
        },
        {
          "scenario": "unmapped_bam_pipeline",
          "workflow_variant_id": "samtools_view_subsample_only",
          "status": "supported",
          "operation_ordering": ["view_subsample"],
          "notes": "Subsample-only BAM path without sort or index."
        },
        {
          "scenario": "mapped_bam_pipeline",
          "workflow_variant_id": "samtools_sort_index",
          "status": "planned",
          "operation_ordering": ["sort", "index"],
          "notes": "Shell wrapper skeleton exists for benchmarking pre-materialized BAM inputs that skip subsampling in the comparator path."
        },
        {
          "scenario": "subsample_only",
          "workflow_variant_id": "samtools_subsample_only",
          "status": "planned",
          "operation_ordering": ["view_subsample"],
          "notes": "Explicit alias for the BAM-only subsampling path."
        },
        {
          "scenario": "fastq_consume_pipeline",
          "workflow_variant_id": "unsupported",
          "status": "unsupported",
          "operation_ordering": [],
          "notes": "Not a suitable FASTQ consume comparator in the current framework."
        },
        {
          "scenario": "subsample_only",
          "workflow_variant_id": "samtools_view_subsample_only",
          "status": "supported",
          "operation_ordering": ["view_subsample"],
          "notes": "BAM-only subsample comparator path."
        }
      ],
      "notes": "Canonical BAM baseline for mapped and unmapped BAM scenarios."
    },
    {
      "id": "fastcat",
      "display_name": "EPI2ME fastcat",
      "category": "consume_normalizer",
      "wrapper": {
        "type": "shell_script",
        "path": "benchmarks/tools/wrappers/fastcat.sh",
        "entrypoint": "benchmarks/tools/wrappers/fastcat.sh",
