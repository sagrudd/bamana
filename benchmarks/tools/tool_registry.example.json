        "cli_contract": "benchmarks/tools/wrappers/wrapper_cli_contract.md",
        "timing_strategy": "plan_then_run_benchmark",
        "supports_threads": false,
        "supports_subsample": false,
        "supports_sort": false,
        "supports_index": false,
        "supports_consume": true
      },
      "version_command": "fastcat --version",
      "supports_scenarios": [
        "fastq_consume_pipeline"
      ],
      "workflow_variants": [
        {
          "scenario": "mapped_bam_pipeline",
          "workflow_variant_id": "unsupported",
          "status": "unsupported",
          "operation_ordering": [],
          "notes": "Not a BAM sort/index comparator."
        },
        {
          "scenario": "unmapped_bam_pipeline",
          "workflow_variant_id": "unsupported",
          "status": "unsupported",
          "operation_ordering": [],
          "notes": "Not an unmapped BAM toolkit comparator."
        },
        {
          "scenario": "fastq_consume_pipeline",
          "workflow_variant_id": "fastcat_concat_gzip",
          "status": "supported",
          "operation_ordering": ["fastcat_concat", "gzip"],
          "notes": "Partial comparator for FASTQ ingestion and concatenation workflows."
        },
        {
          "scenario": "fastq_consume_pipeline",
          "workflow_variant_id": "fastcat_consume_only",
          "status": "planned",
          "operation_ordering": ["fastcat_concat", "gzip"],
          "notes": "Explicit alias wrapper variant for consume-only or concatenation-only planning."
        },
        {
          "scenario": "fastq_consume_pipeline",
          "workflow_variant_id": "fastcat_fastq_concat_only",
          "status": "planned",
          "operation_ordering": ["fastcat_concat", "gzip"],
          "notes": "Explicit alias wrapper variant for concatenation-only benchmarking."
        },
        {
          "scenario": "subsample_only",
          "workflow_variant_id": "unsupported",
          "status": "unsupported",
          "operation_ordering": [],
          "notes": "Not a subsampling comparator."
        }
      ],
      "notes": "Included because one project goal is to beat fastcat in FASTQ ingestion and concatenation space."
    },
