{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://bamana.dev/benchmarks/tools/tool_registry.schema.json",
  "title": "Bamana Benchmark Tool Registry",
  "description": "Machine-readable registry of benchmark comparator tools, wrappers, supported scenarios, and workflow variants.",
  "x-bamana-benchmark-contract-version": "1.0.0",
  "type": "object",
  "additionalProperties": false,
  "required": ["registry_version", "tools"],
  "properties": {
    "registry_version": {
      "type": "string",
      "const": "1.0.0"
    },
    "tools": {
      "type": "array",
      "minItems": 1,
      "items": { "$ref": "#/$defs/tool" }
    }
  },
  "$defs": {
    "scenario": {
      "type": "string",
      "enum": [
        "mapped_bam_pipeline",
        "unmapped_bam_pipeline",
        "fastq_consume_pipeline",
        "subsample_only"
      ]
    },
    "status": {
      "type": "string",
      "enum": ["supported", "unsupported", "planned"]
    },
    "wrapper": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "type",
        "path",
        "entrypoint",
        "supports_threads",
        "supports_subsample",
        "supports_sort",
        "supports_index",
        "supports_consume"
      ],
      "properties": {
        "type": {
          "type": "string",
          "enum": ["nextflow_process", "shell_script", "command_file_plus_timing_wrapper"]
        },
        "path": { "type": "string" },
        "entrypoint": { "type": "string" },
        "orchestration_module": { "type": ["string", "null"] },
        "cli_contract": { "type": ["string", "null"] },
        "timing_strategy": { "type": ["string", "null"] },
        "supports_threads": { "type": "boolean" },
        "supports_subsample": { "type": "boolean" },
        "supports_sort": { "type": "boolean" },
        "supports_index": { "type": "boolean" },
        "supports_consume": { "type": "boolean" }
      }
    },
    "variant": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "scenario",
        "workflow_variant_id",
        "status",
        "operation_ordering",
        "notes"
      ],
      "properties": {
        "scenario": { "$ref": "#/$defs/scenario" },
        "workflow_variant_id": { "type": "string" },
        "status": { "$ref": "#/$defs/status" },
        "operation_ordering": {
          "type": "array",
          "items": { "type": "string" }
        },
        "notes": { "type": "string" }
      }
    },
    "tool": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "id",
        "display_name",
        "category",
        "wrapper",
        "version_command",
        "supports_scenarios",
        "workflow_variants",
        "notes"
      ],
      "properties": {
        "id": {
          "type": "string",
          "enum": ["bamana", "samtools", "sambamba", "seqtk", "rasusa", "fastcat"]
        },
        "display_name": { "type": "string" },
        "category": {
          "type": "string",
          "enum": ["bam_toolkit", "fastq_toolkit", "consume_normalizer", "subsampler", "mixed"]
        },
        "wrapper": { "$ref": "#/$defs/wrapper" },
        "version_command": { "type": "string" },
        "supports_scenarios": {
          "type": "array",
          "items": { "$ref": "#/$defs/scenario" }
        },
        "workflow_variants": {
          "type": "array",
          "items": { "$ref": "#/$defs/variant" }
        },
        "notes": { "type": "string" }
      }
    }
  }
}
