{
  "input_manifest": "benchmarks/inputs/example_manifest.json",
  "dataset_ids": ["hg38_wgs_mapped"],
  "tools": ["bamana", "samtools", "sambamba"],
  "scenarios": ["mapped_bam_pipeline"],
  "replicates": 3,
  "warmup_runs": 1,
  "subsample_fraction": 0.1,
  "subsample_seed": 104729,
  "subsample_mode": "deterministic",
  "threads": 8,
  "output_dir": "/workspace/benchmarks/results/mapped-bam-example",
  "derived_input_dir": "/workspace/benchmarks/results/mapped-bam-example/derived_inputs",
  "enable_plots": true,
  "enable_reports": true,
  "container_engine": "docker",
  "staging_override": "hardlink",
  "include_unsupported_matrix_rows": false,
  "fastcat_enabled": false,
  "storage_context": "local_ssd",
  "cleanup_policy": "retain_derived_retain_failed",
  "reuse_materialized_inputs": true,
  "include_staging_in_timing": false,
  "container_image": "bamana-bench:latest",
  "bamana_bin": "../target/release/bamana"
}
