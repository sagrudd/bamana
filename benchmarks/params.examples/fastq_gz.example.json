{
  "input_manifest": "benchmarks/inputs/example_manifest.json",
  "dataset_ids": ["ont_reads_fastq_gz"],
  "tools": ["bamana", "seqtk", "fastcat"],
  "scenarios": ["fastq_consume_pipeline", "subsample_only"],
  "replicates": 2,
  "warmup_runs": 1,
  "subsample_fraction": 0.25,
  "subsample_seed": 104729,
  "subsample_mode": "random",
  "threads": 4,
  "output_dir": "/workspace/benchmarks/results/fastq-gz-example",
  "derived_input_dir": "/workspace/benchmarks/results/fastq-gz-example/derived_inputs",
  "enable_plots": true,
  "enable_reports": true,
  "container_engine": "docker",
  "staging_override": "scratch_copy",
  "include_unsupported_matrix_rows": true,
  "fastcat_enabled": true,
  "storage_context": "local_ssd",
  "cleanup_policy": "retain_derived_retain_failed",
  "reuse_materialized_inputs": true,
  "include_staging_in_timing": false,
  "container_image": "bamana-bench:latest",
  "bamana_bin": "../target/release/bamana"
}
