manifest {
  name = 'bamana-benchmarks'
  author = 'Mnemosyne Biosciences Ltd'
  description = 'Benchmark suite for Bamana versus samtools, fastcat, and related comparators.'
  nextflowVersion = '>=24.04.0'
}

params {
  input_manifest = null
  mapped_bams = []
  unmapped_bams = []
  fastq_gzs = []
  scenarios = ['mapped_bam_chain', 'unmapped_bam_chain', 'fastq_ingest_chain']
  tools = ['bamana', 'samtools', 'sambamba', 'seqtk', 'rasusa', 'fastcat']
  replicate_count = 3
  warmup_runs = 1
  subsample_fraction = 0.10
  subsample_seed = 104729
  subsample_mode = 'deterministic'
  threads = 4
  max_memory = '16 GB'
  output_dir = "${projectDir}/results/latest"
  derived_input_dir = "${params.output_dir}/derived_inputs"
  staging_mode = 'symlink'
  include_staging_in_timing = false
  reuse_materialized_inputs = true
  storage_context = 'unspecified'
  cleanup_policy = 'retain_derived_retain_failed'
  enable_plotting = true
  container_image = 'bamana-bench:latest'
  bamana_bin = "${projectDir}/../target/release/bamana"
}

process {
  executor = 'local'
  cpus = { params.threads as int }
  memory = { params.max_memory }
  maxRetries = 0
  cache = 'lenient'
}

profiles {
  local {
    includeConfig "${projectDir}/conf/local.config"
  }
  local_ssd {
    includeConfig "${projectDir}/conf/local-ssd.config"
  }
  docker {
    includeConfig "${projectDir}/conf/docker.config"
  }
  shared_fs {
    includeConfig "${projectDir}/conf/shared-fs.config"
  }
}
