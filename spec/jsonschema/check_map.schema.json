{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://bamana.dev/spec/jsonschema/check_map.schema.json",
  "title": "Bamana Check Map Response",
  "description": "Contract for bamana check_map JSON output.",
  "x-bamana-command": "check_map",
  "x-bamana-contract-version": "0.1.0",
  "$defs": {
    "index": {
      "type": "object",
      "additionalProperties": false,
      "required": ["present", "kind", "used"],
      "properties": {
        "present": { "type": "boolean" },
        "kind": { "$ref": "./common/defs.schema.json#/$defs/indexKind" },
        "used": { "type": "boolean" }
      }
    },
    "reference": {
      "type": "object",
      "additionalProperties": false,
      "required": ["name", "length", "mapped_reads", "unmapped_reads", "observed"],
      "properties": {
        "name": { "type": "string" },
        "length": { "type": "integer", "minimum": 0 },
        "mapped_reads": { "type": "integer", "minimum": 0 },
        "unmapped_reads": { "type": "integer", "minimum": 0 },
        "observed": { "type": ["boolean", "null"] }
      }
    },
    "summary": {
      "type": "object",
      "additionalProperties": true,
      "properties": {
        "records_examined": { "type": "integer", "minimum": 0 },
        "mapped_records_observed": { "type": "integer", "minimum": 0 },
        "unmapped_records_observed": { "type": "integer", "minimum": 0 },
        "references_defined": { "type": "integer", "minimum": 0 },
        "references_with_mapped_reads": { "type": "integer", "minimum": 0 },
        "references_with_mapped_reads_observed": { "type": "integer", "minimum": 0 },
        "total_mapped_reads": { "type": "integer", "minimum": 0 },
        "total_unmapped_reads": { "type": "integer", "minimum": 0 }
      }
    },
    "data": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "format",
        "mapping_status",
        "has_mapped_reads",
        "evidence_source",
        "index",
        "references",
        "summary",
        "confidence",
        "semantic_note"
      ],
      "properties": {
        "format": { "const": "BAM" },
        "mapping_status": {
          "type": "string",
          "enum": ["mapped", "unmapped", "indeterminate"]
        },
        "has_mapped_reads": { "type": "boolean" },
        "evidence_source": {
          "type": "string",
          "enum": ["index", "scan", "header", "mixed"]
        },
        "index": { "$ref": "#/$defs/index" },
        "references": {
          "type": "array",
          "items": { "$ref": "#/$defs/reference" }
        },
        "summary": { "$ref": "#/$defs/summary" },
        "confidence": { "$ref": "./common/defs.schema.json#/$defs/confidenceLevel" },
        "status": { "$ref": "./common/defs.schema.json#/$defs/nullableString" },
        "semantic_note": { "type": "string" }
      }
    }
  },
  "oneOf": [
    {
      "type": "object",
      "additionalProperties": false,
      "required": ["ok", "command", "path", "data", "error"],
      "properties": {
        "ok": { "const": true },
        "command": { "const": "check_map" },
        "path": { "$ref": "./common/defs.schema.json#/$defs/pathOrNull" },
        "analysis_wall_seconds": { "type": "number", "minimum": 0 },
        "data": { "$ref": "#/$defs/data" },
        "error": { "type": "null" }
      }
    },
    {
      "type": "object",
      "additionalProperties": false,
      "required": ["ok", "command", "path", "data", "error"],
      "properties": {
        "ok": { "const": false },
        "command": { "const": "check_map" },
        "path": { "$ref": "./common/defs.schema.json#/$defs/pathOrNull" },
        "analysis_wall_seconds": { "type": "number", "minimum": 0 },
        "data": { "oneOf": [{ "$ref": "#/$defs/data" }, { "type": "null" }] },
        "error": { "$ref": "./common/json_error.schema.json" }
      }
    }
  ]
}
